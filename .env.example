# ==============================================================================
# CLAMPBOX & GRAPHXY LABS ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env or .env.local to configure your environments locally.
# Never commit raw secrets or production variables to source control.
# ==============================================================================

# ------------------------------------------------------------------------------
# FRONTEND CONFIGURATION
# ------------------------------------------------------------------------------
# Public API Server Base URL (e.g. for fetch API calls)
VITE_GRAPHXY_API_BASE_URL=http://localhost:5000/api/clampbox

# Feature toggles
VITE_CLAMPBOX_ENABLE_WAITLIST=true
VITE_CLAMPBOX_ENABLE_DASHBOARD=true

# Chrome Extension ID (for message passing to content scripts)
VITE_CLAMPBOX_EXTENSION_ID=abcdefghijklmnopqrstuvwxyzabcdef

# Formspree ID for fallback Waitlist submission
VITE_FORMSPREE_WAITLIST_ID=xpzvoldo

# ------------------------------------------------------------------------------
# BACKEND SERVER CONFIGURATION
# ------------------------------------------------------------------------------
# Server runtime port
PORT=5000
NODE_ENV=development

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# PostgreSQL database connection URL
# Default local dev: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://clampbox:password@localhost:5433/clampbox

# ------------------------------------------------------------------------------
# CACHE CONFIGURATION
# ------------------------------------------------------------------------------
# Redis connection URL for rate limiting, locks, and policy syncing
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# SECURITY & ENCRYPTION
# ------------------------------------------------------------------------------
# Secret key used for symmetric AES encryption of provider keys in Vault.
# MUST be cryptographically strong, 32 bytes hex encoded.
CLAMPBOX_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Secret salt / pepper used during hashing of customer API Gateway keys
CLAMPBOX_GATEWAY_KEY_PEPPER=some_random_pepper_string_for_hashing

# Express session cookie secret
CLAMPBOX_SESSION_SECRET=session_signing_secret_phrase

# ------------------------------------------------------------------------------
# CORS (CROSS-ORIGIN RESOURCE SHARING)
# ------------------------------------------------------------------------------
# Comma-separated list of origins allowed to call API endpoints
CLAMPBOX_ALLOWED_ORIGINS=http://localhost:5173,https://graphxylabs.dev

# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------
# Request throttling limits
CLAMPBOX_RATE_LIMIT_WINDOW_SECONDS=60
CLAMPBOX_RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------------------------------------------
# AUDIT & LOGGING
# ------------------------------------------------------------------------------
# Number of days to retain immutable audit log records before pruning
CLAMPBOX_AUDIT_RETENTION_DAYS=90

# ------------------------------------------------------------------------------
# THIRD-PARTY INTEGRATIONS (VAULT PROVIDERS)
# ------------------------------------------------------------------------------
# Initial fallback provider variables (if not set in user organization database)
OPENAI_API_KEY=sk-proj-placeholder
ANTHROPIC_API_KEY=sk-ant-placeholder
GEMINI_API_KEY=ai-gem-placeholder
